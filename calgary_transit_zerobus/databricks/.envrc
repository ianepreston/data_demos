if ! command -v uv >/dev/null 2>&1; then
  echo "ERROR: uv not found. Install uv first." >&2
  exit 1
fi
uv python install
if [ ! -d .venv ]; then
  uv venv
fi
PATH_add ".venv/bin"
export VIRTUAL_ENV="$PWD/.venv"
watch_file pyproject.toml
watch_file uv.lock
if [ -f uv.lock ]; then
  uv sync --frozen || uv sync
else
  uv sync
fi
prek autoupdate
dotenv_if_exists
export SERVER_ENDPOINT="https://7405616154229592.zerobus.westus2.azuredatabricks.net"
export DATABRICKS_WORKSPACE_URL="https://adb-7405616154229592.12.azuredatabricks.net/"
dotenv_if_exists ../terraform/sp_credentials.env
