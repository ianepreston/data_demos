[project]
name = "data-demos"
version = "0.1.0"
description = "Add your description here"
readme = "README.md"
authors = [
  { name = "ianepreston", email = "17241371+ianepreston@users.noreply.github.com" },
]
requires-python = ">=3.11"
dependencies = ["gtfs-realtime-bindings>=2.0.0", "requests>=2.32.5"]

[build-system]
requires = ["uv_build>=0.10.4,<0.11.0"]
build-backend = "uv_build"


[dependency-groups]
dev = [
  "databricks-sdk>=0.102.0",
  "ipython>=9.10.0",
  "prek>=0.3.8",
  "pyspark>=4.1.1",
  "pytest>=9.0.2",
  "ruff>=0.15.7",
]

[tool.ruff]
builtins = ["spark"]
